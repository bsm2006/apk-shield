# APK Malware Analysis Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ===== DATABASE =====
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://apkuser:apkpassword@db:5432/apkdb
# SQLite (fallback - no setup needed)
# DATABASE_URL=sqlite:///./apk_analysis.db

# ===== AI PROVIDER =====
# Choose: "gemini" or "openai"
AI_PROVIDER=gemini

# Google Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ===== SERVER =====
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ===== SECURITY =====
SECRET_KEY=your-secret-key-change-in-production-32chars-minimum

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== FILE UPLOAD =====
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=uploads
